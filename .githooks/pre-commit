#!/usr/bin/env bash
# Pre-commit hook
#
# 1. Runs pre-commit hooks (auto-format, lint, type-check).
#    Formatters that modify files will cause the hook to exit non-zero so the
#    developer can review, but we automatically re-stage the fixed files to
#    reduce friction.
# 2. Runs the bootstrap test suite (bash syntax + shellcheck + pytest).

set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

# ── Helpers ──────────────────────────────────────────────────────────────────
log() { printf '[pre-commit] %s\n' "$*"; }
warn() { printf '[pre-commit] WARN: %s\n' "$*" >&2; }

# ── pre-commit (auto-format, lint, type-check) ────────────────────────────────
if command -v pre-commit >/dev/null 2>&1 && [[ -f "$ROOT_DIR/.pre-commit-config.yaml" ]]; then
    log "Running pre-commit hooks..."

    # Capture which files were staged before pre-commit runs.
    mapfile -t staged_before < <(git diff --name-only --cached)

    set +e
    pre-commit run --from-ref HEAD --to-ref HEAD 2>/dev/null \
        || pre-commit run 2>/dev/null
    pc_exit=$?
    set -e

    if [[ $pc_exit -ne 0 ]]; then
        # Re-stage files that pre-commit auto-fixed so the commit includes the
        # formatted version rather than forcing the developer to run git add manually.
        mapfile -t modified_after < <(git diff --name-only)
        restaged=0
        for f in "${modified_after[@]}"; do
            # Only re-stage files that were already staged before the hook ran.
            for s in "${staged_before[@]}"; do
                if [[ "$f" == "$s" ]]; then
                    git add -- "$f"
                    log "Re-staged (auto-fixed): $f"
                    restaged=$((restaged + 1))
                    break
                fi
            done
        done

        if [[ $restaged -gt 0 ]]; then
            warn "$restaged file(s) were auto-fixed and re-staged."
            warn "Please review the changes and commit again."
        else
            warn "pre-commit reported errors. Fix them and commit again."
        fi

        exit 1
    fi

    log "pre-commit passed."
else
    log "pre-commit not found or no config; skipping auto-format/lint step."
    log "Install with: uv tool install pre-commit"
fi

# ── Bootstrap test suite ──────────────────────────────────────────────────────
log "Running bootstrap checks..."
bash scripts/test.sh
